# RuVocal UI — Environment Configuration Example
# Copy this file to .env.local and fill in real values:  cp .env.example .env.local
# (Alternatively, generate .env.local from the chart:    npm run updateLocalEnv)
# NEVER commit .env / .env.local — only this template and .env.ci are tracked.
#
# RuVocal is a HuggingChat (chat-ui) fork rewired onto RuVector's own storage:
# persistence is an RVF-backed document store (NOT MongoDB — the README/CLAUDE.md
# note about MongoDB is stale; code-truth: src/lib/server/database.ts), with an
# optional pgvector backend (ruvector-postgres). It speaks OpenAI-compatible APIs.

# ============================================
# Persistence — RVF document store (primary)
# ============================================
# Directory for the self-contained RVF document store (the store file
# ruvocal.rvf.json is created inside it). Defaults to ./db if unset.
RVF_DB_PATH=./db
# Secret used by the rvf-crypto witness chain. Generate a random value, e.g.:
#   openssl rand -hex 32
RVF_KERNEL_SECRET=replace-with-openssl-rand-hex-32

# Optional: pgvector backend (ruvector-postgres). Leave unset to use RVF only.
# DATABASE_URL=postgres://user:pass@localhost:5432/ruvocal

# Legacy: only read by scripts/populate.ts (seeding). Not used by the running app.
# MONGODB_URL=mongodb://localhost:27017/

# ============================================
# LLM provider (OpenAI-compatible endpoint)
# ============================================
OPENAI_BASE_URL=https://router.huggingface.co/v1
# Provider key. For the HF router, use your HF token here.
OPENAI_API_KEY=hf_your-token-here
HF_TOKEN=hf_your-token-here
# Optional alternate providers (env-only secrets per rvf.manifest.json):
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# GOOGLE_API_KEY=your-google-ai-key-here
# OPENROUTER_API_KEY=your-openrouter-key-here

# ============================================
# Embeddings (vector search)
# ============================================
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
EMBEDDING_DIMENSIONS=1024

# ============================================
# MCP — the universal control seam
# ============================================
# Bridge URL the UI talks to for MCP capabilities.
MCP_BRIDGE_URL=http://localhost:3001
# JSON map of MCP servers to expose as tools (see chart/env/dev.yaml for format).
# MCP_SERVERS={}
MCP_TOOL_TIMEOUT_MS=120000

# ============================================
# Server / app
# ============================================
PORT=3000
APP_BASE=
ALLOW_IFRAME=false
BRAND_NAME=RuVocal
PUBLIC_APP_ASSETS=huggingchat
# PUBLIC_VERSION / PUBLIC_COMMIT_SHA are injected at build time.

# ============================================
# Auth (OpenID Connect) — optional for local dev
# ============================================
# OPENID_PROVIDER_URL=
# OPENID_CLIENT_ID=
# OPENID_CLIENT_SECRET=

# ============================================
# Config manager (optional)
# ============================================
# Set to "true" to let the RVF-backed config collection override env values.
# ENABLE_CONFIG_MANAGER=false
# SECRET_CONFIG can hold a newline-delimited block of additional KEY=`value` pairs.

# Session / auth (REQUIRED): empty COOKIE_NAME makes cookies.set() throw and crashes the UI
COOKIE_NAME=ruvocal-session
PUBLIC_ORIGIN=http://localhost:5173
PUBLIC_APP_NAME=RuVocal

# --- MCP tool servers (the UI calls these as tools; JSON array of {name,url}) ---
# Run the ruvector substrate MCP server:  target/release/ruvector-mcp -t sse --host 127.0.0.1 --port 3001
# Its StreamableHTTP endpoint is /mcp. pi-brain SSE: https://pi.ruv.io/sse
MCP_SERVERS=[{"name":"ruvector","url":"http://127.0.0.1:3001/mcp"},{"name":"pi-brain","url":"https://pi.ruv.io/sse","headers":{"Authorization":"Bearer <brain-api-key>"}}]

# prompt_hub REST-bridge (ADR-262) — RuVocal server proxies prompthub-server (axum) directly.
PROMPTHUB_URL=http://127.0.0.1:8077
