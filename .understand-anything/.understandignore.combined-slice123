# Combined slice 1+2+3 scope — covers everything currently in knowledge-graph.json
#
# Slice 1: top-level + crates/{ruvector-cli, ruvector-core} + npm-root manifests
# Slice 2: crates/{mcp-brain, mcp-brain-server, mcp-gate}
# Slice 3: crates/{ruvector-math, ruvector-graph, ruvector-dag, ruvector-cnn}
#
# Future slice runs: swap this for a slice-N scope, run /understand, rename output
# to slice-N-knowledge-graph.json, then restore this combined version and re-run
# /understand to trigger the auto-merge.

# Default-excluded scaffolding
.cargo/
.claude/
.github/
.githooks/
benches/
benchmarks/
bench_results/
data/
docs/
examples/
patches/
scripts/
target/
test_models/
tests/
ui/
node_modules/

# npm/ — keep top-level manifests + READMEs, drop the large subtrees
npm/core/
npm/packages/
npm/wasm/
npm/tests/

# Cargo.lock is huge and isn't analyzable structure
Cargo.lock
package-lock.json

# Exclude all crates by default, then re-include slice 1+2+3 targets
