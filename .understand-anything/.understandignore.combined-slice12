# Combined slice 1+2 scope — covers everything currently in knowledge-graph.json
#
# Slice 1: top-level + crates/{ruvector-cli, ruvector-core} + npm-root manifests
# Slice 2: crates/{mcp-brain, mcp-brain-server, mcp-gate}
#
# Future slice runs: change this file to point at the new slice scope, run /understand,
# rename output to slice-N-knowledge-graph.json, then restore this combined version.

# Default-excluded scaffolding
.cargo/
.claude/
.github/
.githooks/
benches/
benchmarks/
bench_results/
data/
docs/
examples/
patches/
scripts/
target/
test_models/
tests/
ui/
node_modules/

# npm/ — keep top-level manifests + READMEs, drop the large subtrees
npm/core/
npm/packages/
npm/wasm/
npm/tests/

# Cargo.lock is huge (329 KB) and isn't analyzable structure
Cargo.lock
package-lock.json

# Exclude all crates by default, then re-include slice 1 + slice 2 targets
crates/*
!crates/ruvector-cli/
!crates/ruvector-cli/**
!crates/ruvector-core/
!crates/ruvector-core/**
!crates/mcp-brain/
!crates/mcp-brain/**
!crates/mcp-brain-server/
!crates/mcp-brain-server/**
!crates/mcp-gate/
!crates/mcp-gate/**
