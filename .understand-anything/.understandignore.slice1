# Slice 1 — "what does cargo install ruvector-cli actually deliver"
# In scope: top-level + crates/{ruvector-cli, ruvector-core} + npm root manifests + .ruvector/

# All top-level subdirs that are NOT in slice 1:
.cargo/
.claude/
.github/
.githooks/
benches/
benchmarks/
bench_results/
data/
docs/
examples/
patches/
scripts/
target/
test_models/
tests/
ui/
node_modules/

# npm/ — keep manifests + READMEs, drop the large subtrees
npm/core/
npm/packages/
npm/wasm/
npm/tests/

# Cargo.lock is huge (329 KB) and isn't analyzable structure
Cargo.lock
package-lock.json

# Exclude all crates by default, re-include slice 1
crates/*
!crates/ruvector-cli/
!crates/ruvector-cli/**
!crates/ruvector-core/
!crates/ruvector-core/**
