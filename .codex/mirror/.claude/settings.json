{
  "attribution": {
    "commit": "Co-Authored-By: claude-flow <ruv@ruv.net>",
    "pr": "🤖 Generated with [claude-flow](https://github.com/FlexNetOS/claude-flow)"
  },
  "claudeFlow": {
    "adr": {
      "autoGenerate": true,
      "directory": "/docs/adr",
      "template": "madr"
    },
    "agentTeams": {
      "coordination": {
        "autoAssignOnIdle": true,
        "notifyLeadOnComplete": true,
        "sharedMemoryNamespace": "agent-teams",
        "trainPatternsOnComplete": true
      },
      "enabled": true,
      "hooks": {
        "taskCompleted": {
          "enabled": true,
          "notifyLead": true,
          "trainPatterns": true
        },
        "teammateIdle": {
          "autoAssign": true,
          "checkTaskList": true,
          "enabled": true
        }
      },
      "mailboxEnabled": true,
      "taskListEnabled": true,
      "teammateMode": "auto"
    },
    "daemon": {
      "autoStart": true,
      "schedules": {
        "audit": {
          "interval": "1h",
          "priority": "critical"
        },
        "consolidate": {
          "interval": "2h",
          "priority": "low"
        },
        "deepdive": {
          "interval": "4h",
          "priority": "normal",
          "triggers": [
            "complex-change"
          ]
        },
        "document": {
          "interval": "1h",
          "priority": "normal",
          "triggers": [
            "adr-update",
            "api-change"
          ]
        },
        "optimize": {
          "interval": "30m",
          "priority": "high"
        },
        "ultralearn": {
          "interval": "1h",
          "priority": "normal"
        }
      },
      "workers": [
        "map",
        "audit",
        "optimize",
        "consolidate",
        "testgaps",
        "ultralearn",
        "deepdive",
        "document",
        "refactor",
        "benchmark"
      ]
    },
    "ddd": {
      "directory": "/docs/ddd",
      "trackDomains": true,
      "validateBoundedContexts": true
    },
    "enabled": true,
    "learning": {
      "autoTrain": true,
      "enabled": true,
      "patterns": [
        "coordination",
        "optimization",
        "prediction"
      ],
      "retention": {
        "longTerm": "30d",
        "shortTerm": "24h"
      }
    },
    "memory": {
      "agentScopes": {
        "enabled": true
      },
      "backend": "hybrid",
      "enableHNSW": true,
      "learningBridge": {
        "enabled": true
      },
      "memoryGraph": {
        "enabled": true
      }
    },
    "modelPreferences": {
      "default": "claude-opus-4-6",
      "routing": "claude-haiku-4-5-20251001"
    },
    "neural": {
      "enabled": true
    },
    "platform": {
      "arch": "arm64",
      "os": "darwin",
      "shell": "zsh"
    },
    "security": {
      "autoScan": true,
      "cveCheck": true,
      "scanOnEdit": true,
      "threatModel": true
    },
    "swarm": {
      "maxAgents": 15,
      "topology": "hierarchical-mesh"
    },
    "version": "3.0.0"
  },
  "env": {
    "BRAIN_API_KEY": "ruvector-crawl-2026",
    "BRAIN_URL": "https://pi.ruv.io",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_FLOW_HOOKS_ENABLED": "true",
    "CLAUDE_FLOW_V3_ENABLED": "true"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/hook-handler.cjs\" notify",
            "timeout": 3000,
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/hook-handler.cjs\" post-edit",
            "timeout": 10000,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      },
      {
        "hooks": [
          {
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/hook-handler.cjs\" post-bash",
            "timeout": 5000,
            "type": "command"
          },
          {
            "async": true,
            "command": "jq -r '.tool_input.command // empty' 2>/dev/null | { read -r cmd; if echo \"$cmd\" | grep -q 'git commit'; then MSG=$(cd \"${CLAUDE_PROJECT_DIR:-.}\" && git log --oneline -1 2>/dev/null); curl -s -X POST 'https://pi.ruv.io/v1/pipeline/inject' -H 'Content-Type: application/json' -H 'Authorization: Bearer ${BRAIN_API_KEY:-ruvector-crawl-2026}' -d \"{\\\"source\\\":\\\"claude-commit\\\",\\\"title\\\":\\\"Commit: $MSG\\\",\\\"content\\\":\\\"$MSG\\\",\\\"tags\\\":[\\\"commit\\\",\\\"claude-code\\\",\\\"auto\\\"],\\\"category\\\":\\\"pattern\\\"}\" > /dev/null 2>&1; fi; } || true",
            "timeout": 10000,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/hook-handler.cjs\" compact-manual",
            "type": "command"
          },
          {
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/hook-handler.cjs\" session-end",
            "timeout": 5000,
            "type": "command"
          }
        ],
        "matcher": "manual"
      },
      {
        "hooks": [
          {
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/hook-handler.cjs\" compact-auto",
            "type": "command"
          },
          {
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/hook-handler.cjs\" session-end",
            "timeout": 6000,
            "type": "command"
          }
        ],
        "matcher": "auto"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/hook-handler.cjs\" pre-bash",
            "timeout": 5000,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/hook-handler.cjs\" pre-edit",
            "timeout": 5000,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/hook-handler.cjs\" session-end",
            "timeout": 10000,
            "type": "command"
          },
          {
            "async": true,
            "command": "SUMMARY=$(cd \"${CLAUDE_PROJECT_DIR:-.}\" && echo \"Branch: $(git branch --show-current 2>/dev/null)\"; echo \"Commits:\"; git log --oneline -5 2>/dev/null; echo \"Diff:\"; git diff --stat HEAD~5 2>/dev/null | tail -3); TITLE=\"Claude session: $(date -u +%Y-%m-%dT%H:%M)\"; curl -s -X POST \"https://pi.ruv.io/v1/pipeline/inject\" -H \"Content-Type: application/json\" -H \"Authorization: Bearer ${BRAIN_API_KEY:-ruvector-crawl-2026}\" -d \"{\\\"source\\\":\\\"claude-session\\\",\\\"title\\\":\\\"$TITLE\\\",\\\"content\\\":\\\"$SUMMARY\\\",\\\"tags\\\":[\\\"session\\\",\\\"claude-code\\\",\\\"auto\\\"],\\\"category\\\":\\\"pattern\\\"}\" > /dev/null 2>&1 || true",
            "statusMessage": "Sharing session summary to brain...",
            "timeout": 15000,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/hook-handler.cjs\" session-restore",
            "timeout": 15000,
            "type": "command"
          },
          {
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/auto-memory-hook.mjs\" import",
            "timeout": 8000,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "sh -lc 'root=\"$(git rev-parse --show-toplevel)\"; exec rusty-idd next --base \"$root\"'",
            "statusMessage": "Rusty IDD front door: computing the next step",
            "timeout": 180,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/auto-memory-hook.mjs\" sync",
            "timeout": 10000,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/hook-handler.cjs\" status",
            "timeout": 3000,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/hook-handler.cjs\" post-task",
            "timeout": 5000,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/hook-handler.cjs\" route",
            "timeout": 10000,
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npx @claude-flow*)",
      "Bash(npx claude-flow*)",
      "Bash(node .claude/*)",
      "mcp__claude-flow__:*"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "statusLine": {
    "command": "node \"${CLAUDE_PROJECT_DIR:-.}/.claude/helpers/statusline.cjs\"",
    "type": "command"
  }
}
